{
  "name": "obsidian-crdt-sync",
  "private": true,
  "packageManager": "bun@1.3.10",
  "type": "module",
  "module": "src/main.ts",
  "scripts": {
    "build": "bun build src/main.ts --outfile=main.js --format=cjs --target=browser --minify --external=obsidian --external=electron --external=@codemirror/autocomplete --external=@codemirror/collab --external=@codemirror/commands --external=@codemirror/language --external=@codemirror/lint --external=@codemirror/search --external=@codemirror/state --external=@codemirror/view --external=@lezer/common --external=@lezer/highlight --external=@lezer/lr",
    "check": "biome check --write .",
    "dev": "bun build src/main.ts --outfile=main.js --format=cjs --target=browser --minify --external=obsidian --external=electron --external=@codemirror/autocomplete --external=@codemirror/collab --external=@codemirror/commands --external=@codemirror/language --external=@codemirror/lint --external=@codemirror/search --external=@codemirror/state --external=@codemirror/view --external=@lezer/common --external=@lezer/highlight --external=@lezer/lr --watch",
    "prepare": "husky",
    "release": "bun run release.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hocuspocus/provider": "3.4.4",
    "diff-match-patch": "1.0.5",
    "ignore": "7.0.5",
    "yjs": "13.6.29"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.7",
    "@hocuspocus/server": "3.4.4",
    "@types/bun": "1.3.10",
    "@types/diff-match-patch": "1.0.36",
    "husky": "9.1.7",
    "obsidian": "1.11.4",
    "typescript": "5.9.3"
  }
}
